# Copy to signal-server/.env for local development
# Replace every placeholder before running outside an isolated local environment.

PORT=8080
CORS_ORIGIN=http://127.0.0.1:8080,http://localhost:8080

JWT_SECRET=replace-with-32-plus-random-chars
VIEWER_ACCESS_PASSWORD=replace-with-viewer-password
HOST_SHARED_SECRET=replace-with-host-shared-secret

# Optional STUN/TURN
STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=

# Optional diagnostics persistence (default off)
WRD_ENABLE_DIAG_PERSIST=0
